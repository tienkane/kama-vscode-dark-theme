    "// === Buttons ===": "",
    "button.background": "#b9a482",
    "button.foreground": "#241c18",
    "button.hoverBackground": "#c9b893",
    "button.secondaryBackground": "#45382c",
    "button.secondaryForeground": "#ddcfaf",
    "button.secondaryHoverBackground": "#524436",
    "badge.background": "#b9a482",
    "badge.foreground": "#241c18",

    "// === Scrollbar ===": "",
    "scrollbar.shadow": "#00000000",
    "scrollbarSlider.background": "#5e4f4045",
    "scrollbarSlider.hoverBackground": "#5e4f4070",
    "scrollbarSlider.activeBackground": "#b9a48270",

    "// === Panels (terminal/output) ===": "",
    "panel.background": "#211a15",
    "panel.border": "#00000000",
    "panelTitle.activeForeground": "#ddcfaf",
    "panelTitle.activeBorder": "#b9a482",
    "panelTitle.inactiveForeground": "#8a7050",

    "// === Terminal ===": "",
    "terminal.background": "#1c1512",
    "terminal.foreground": "#c4b694",
    "terminalCursor.foreground": "#c9b893",
    "terminal.ansiBlack": "#241c18",
    "terminal.ansiRed": "#cb7a74",
    "terminal.ansiGreen": "#a0a47c",
    "terminal.ansiYellow": "#c6ac86",
    "terminal.ansiBlue": "#9d8a6e",
    "terminal.ansiMagenta": "#b58578",
    "terminal.ansiCyan": "#b9a482",
    "terminal.ansiWhite": "#ddcfaf",
    "terminal.ansiBrightBlack": "#6d5d4c",
    "terminal.ansiBrightRed": "#d68f89",
    "terminal.ansiBrightGreen": "#b3b78e",
    "terminal.ansiBrightYellow": "#d8cbae",
    "terminal.ansiBrightBlue": "#c4b08c",
    "terminal.ansiBrightMagenta": "#cda094",
    "terminal.ansiBrightCyan": "#c9b893",
    "terminal.ansiBrightWhite": "#f5e8cc",

    "// === Git decorations ===": "",
    "gitDecoration.modifiedResourceForeground": "#b9a482",
    "gitDecoration.deletedResourceForeground": "#cb7a74",
    "gitDecoration.untrackedResourceForeground": "#a0a47c",
    "gitDecoration.ignoredResourceForeground": "#5e4f40",
    "gitDecoration.conflictingResourceForeground": "#c39873",

    "// === Diff editor ===": "",
    "diffEditor.insertedTextBackground": "#a0a47c1f",
    "diffEditor.removedTextBackground": "#9a4f4c1f",

    "// === Peek view ===": "",
    "peekView.border": "#b9a482",
    "peekViewEditor.background": "#2a211c",
    "peekViewResult.background": "#1c1512",
    "peekViewTitle.background": "#1c1512",
    "peekViewResult.selectionBackground": "#45382c",

    "// === Misc ===": "",
    "menu.background": "#1c1512",
    "menu.foreground": "#c4b694",
    "menu.selectionBackground": "#45382c",
    "menu.selectionForeground": "#ddcfaf",
    "menu.border": "#322820",
    "menubar.selectionBackground": "#322820",
    "breadcrumb.foreground": "#8a7050",
    "breadcrumb.focusForeground": "#ddcfaf",
    "breadcrumb.activeSelectionForeground": "#c6ac86",
    "breadcrumbPicker.background": "#1c1512",
    "notificationCenterHeader.background": "#1c1512",
    "notifications.background": "#241c18",
    "notifications.border": "#45382c",
    "textLink.foreground": "#b9a482",
    "textLink.activeForeground": "#c9b893",
    "textBlockQuote.background": "#241c18",
    "textBlockQuote.border": "#b9a482",
    "textCodeBlock.background": "#1c1512",
    "textPreformat.foreground": "#c6ac86",
    "minimap.findMatchHighlight": "#b9a482",
    "progressBar.background": "#b9a482",
    "pickerGroup.foreground": "#b9a482",
    "pickerGroup.border": "#322820",
    "keybindingLabel.background": "#322820",
    "keybindingLabel.foreground": "#c4b694",
    "keybindingLabel.border": "#45382c",
    "charts.foreground": "#c4b694",
    "charts.lines": "#5e4f40",
    "charts.red": "#cb7a74",
    "charts.green": "#a0a47c",
    "charts.yellow": "#c6ac86",
    "charts.orange": "#c39873",
    "charts.blue": "#9d8a6e",
    "charts.purple": "#b58578"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#82705a", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "constant.other.symbol"],
      "settings": { "foreground": "#a0a47c" }
    },
    {
      "name": "String escapes / template expressions",
      "scope": [
        "constant.character.escape",
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#c39873" }
    },
    {
      "name": "Numbers, constants, booleans",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "support.constant"
      ],
      "settings": { "foreground": "#c39873" }
    },
    {
      "name": "Keywords, storage, operators (text)",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.operator.expression",
        "keyword.operator.new",
        "keyword.operator.logical"
      ],
      "settings": { "foreground": "#c6ac86" }
    },
    {
      "name": "Operators / punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": { "foreground": "#9d8a6e" }
    },
    {
      "name": "Functions / methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "variable.function"
      ],
      "settings": { "foreground": "#cdc0a0" }
    },
    {
      "name": "Types / classes / interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "entity.name.namespace"
      ],
      "settings": { "foreground": "#c0aa84" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "meta.definition.variable.name", "variable.other.readwrite"],
      "settings": { "foreground": "#ccbd9a" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#c4b08c", "fontStyle": "italic" }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.variable.property"
      ],
      "settings": { "foreground": "#c4b694" }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": ["variable.language", "variable.language.this"],
      "settings": { "foreground": "#c39873", "fontStyle": "italic" }
    },
    {
      "name": "Constants / enums (uppercase)",
      "scope": ["variable.other.constant", "entity.name.constant"],
      "settings": { "foreground": "#c6ac86" }
    },
    {
      "name": "Decorators",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#a8896c" }
    },
    {
      "name": "HTML/JSX tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#c4936a" }
    },
    {
      "name": "HTML/JSX attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#c6ac86", "fontStyle": "italic" }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css", "meta.property-name"],
      "settings": { "foreground": "#c4b694" }
    },
    {
      "name": "CSS classes / ids / selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": { "foreground": "#c0aa84" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#c6ac86", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#cdc0a0", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#c4b694", "fontStyle": "italic" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#b9a482" }
    },
    {
      "name": "Markdown code / quote",
      "scope": ["markup.inline.raw", "markup.fenced_code", "markup.quote"],
      "settings": { "foreground": "#a0a47c" }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#c6ac86" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#cb7a74" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#82705a", "fontStyle": "strikethrough" }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#c4b08c",
    "property": "#c4b694",
    "variable.readonly": "#c6ac86",
    "enumMember": "#c39873",
    "function": "#cdc0a0",
    "method": "#cdc0a0",
    "class": "#c0aa84",
    "interface": "#c0aa84",
    "type": "#c0aa84",
    "namespace": "#c4b08c"
  }
}
