    "list.inactiveSelectionForeground": "#c4b694",
    "list.hoverBackground": "#2a211c",
    "list.hoverForeground": "#ddcfaf",
    "list.focusBackground": "#45382c",
    "list.highlightForeground": "#c6ac86",
    "tree.indentGuidesStroke": "#3a2f26",

    "// === Tabs ===": "",
    "editorGroupHeader.tabsBackground": "#1a1410",
    "editorGroupHeader.tabsBorder": "#00000000",
    "editorGroup.border": "#00000000",
    "tab.activeBackground": "#2a211c",
    "tab.activeForeground": "#ddcfaf",
    "tab.activeBorderTop": "#00000000",
    "tab.inactiveBackground": "#1a1410",
    "tab.inactiveForeground": "#8a7050",
    "tab.border": "#322820",
    "tab.hoverBackground": "#2a211c",
